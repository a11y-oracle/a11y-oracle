{
  "name": "@a11y-oracle/axe-bridge",
  "version": "1.1.0",
  "description": "Axe-core result post-processor that resolves 10 incomplete rules using visual analysis, keyboard interaction, and CDP inspection",
  "license": "MIT",
  "author": "a11y-oracle",
  "repository": {
    "type": "git",
    "url": "https://github.com/a11y-oracle/a11y-oracle.git",
    "directory": "libs/axe-bridge"
  },
  "bugs": {
    "url": "https://github.com/a11y-oracle/a11y-oracle/issues"
  },
  "homepage": "https://github.com/a11y-oracle/a11y-oracle/tree/main/libs/axe-bridge",
  "keywords": [
    "accessibility",
    "a11y",
    "axe-core",
    "wcag",
    "color-contrast",
    "focus-indicator",
    "target-size",
    "cdp",
    "testing"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@a11y-oracle/cdp-types": "1.1.0",
    "@a11y-oracle/focus-analyzer": "1.1.0",
    "@a11y-oracle/keyboard-engine": "1.1.0",
    "@a11y-oracle/visual-engine": "1.1.0",
    "tslib": "^2.3.0"
  }
}
