{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": false,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts"],
  "references": [
    {
      "path": "../cdp-types/tsconfig.lib.json"
    },
    {
      "path": "../focus-analyzer/tsconfig.lib.json"
    },
    {
      "path": "../keyboard-engine/tsconfig.lib.json"
    },
    {
      "path": "../visual-engine/tsconfig.lib.json"
    }
  ]
}
