{
  "name": "@a11y-oracle/audit-formatter",
  "version": "0.0.1",
  "description": "Converts accessibility findings to axe-core-compatible OracleIssue objects with WCAG rule metadata",
  "license": "MIT",
  "author": "HSA Health Plan",
  "repository": {
    "type": "git",
    "url": "https://github.com/HSAHealthPlan/a11y-oracle.git",
    "directory": "libs/audit-formatter"
  },
  "bugs": {
    "url": "https://github.com/HSAHealthPlan/a11y-oracle/issues"
  },
  "homepage": "https://github.com/HSAHealthPlan/a11y-oracle/tree/main/libs/audit-formatter",
  "keywords": [
    "accessibility",
    "a11y",
    "audit",
    "wcag",
    "axe-core",
    "testing",
    "formatter"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@a11y-oracle/core-engine": "0.0.1",
    "@a11y-oracle/focus-analyzer": "0.0.1",
    "tslib": "^2.3.0"
  }
}
